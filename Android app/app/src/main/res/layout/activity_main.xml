<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgColor"
    tools:context=".MainActivity">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            app:tint="@color/textColorPrimary" />

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="16dp"
            android:src="@android:drawable/ic_menu_gallery"
            app:tint="@color/colorPrimary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VQA"
                android:textColor="@color/textColorPrimary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Visual Question Answering"
                android:textColor="@color/textColorSecondary"
                android:textSize="10sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:text="PRO"
            android:textColor="@color/colorPrimary"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/bottomInputBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:clipToPadding="false"
        android:paddingBottom="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Image Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_main_card"
                android:padding="32dp"
                android:gravity="center">

                <ImageView
                    android:id="@+id/ivPreview"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@android:drawable/ic_menu_gallery"
                    app:tint="@color/colorPrimary"
                    android:scaleType="centerCrop" />

                <TextView
                    android:id="@+id/tvDropText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Drop your image here"
                    android:textColor="@color/textColorPrimary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp" />

                <TextView
                    android:id="@+id/tvFormats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PNG • JPG • WEBP • GIF"
                    android:textColor="@color/textColorSecondary"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp" />

                <Button
                    android:id="@+id/btnBrowse"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_btn_gradient"
                    android:text="Browse files"
                    android:textColor="@color/textColorPrimary"
                    android:textAllCaps="false"
                    android:layout_marginTop="24dp" />

                <Button
                    android:id="@+id/btnCamera"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_btn_outline"
                    android:text="Camera"
                    android:textColor="@color/textColorPrimary"
                    android:textAllCaps="false"
                    android:layout_marginTop="12dp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ask AI anything\nabout your image"
                android:textColor="@color/textColorPrimary"
                android:textSize="28sp"
                android:textStyle="bold"
                android:lineSpacingExtra="4dp"
                android:layout_marginTop="32dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Powered by ViLT Vision-Language Transformer"
                android:textColor="@color/textColorSecondary"
                android:textSize="14sp"
                android:layout_marginTop="8dp" />

            <!-- Chips -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/chip1"
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_chip"
                        android:padding="16dp"
                        android:text="What's in this image?"
                        android:textColor="@color/textColorPrimary"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/chip2"
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_chip"
                        android:padding="16dp"
                        android:text="What color is this?"
                        android:textColor="@color/textColorPrimary"
                        android:textSize="12sp"
                        android:layout_marginStart="8dp" />

                    <TextView
                        android:id="@+id/chip3"
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_chip"
                        android:padding="16dp"
                        android:text="Count people in this image"
                        android:textColor="@color/textColorPrimary"
                        android:textSize="12sp"
                        android:layout_marginStart="8dp" />
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:id="@+id/tvAnswer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/textColorPrimary"
                android:textSize="24sp"
                android:layout_marginTop="24dp"
                android:visibility="gone" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="24dp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Sticky Bar -->
    <LinearLayout
        android:id="@+id/bottomInputBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_input_box"
        android:padding="8dp"
        android:layout_margin="16dp"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/etQuestion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@null"
            android:hint="Ask anything about your image..."
            android:textColorHint="@color/textColorSecondary"
            android:textColor="@color/textColorPrimary"
            android:padding="12dp"
            android:textSize="14sp"
            android:inputType="text" />

        <ImageButton
            android:id="@+id/btnMic"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_chip"
            android:src="@android:drawable/ic_btn_speak_now"
            app:tint="@color/colorPrimary"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnSubmit"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:background="@drawable/bg_btn_gradient"
            android:text="Ask AI"
            android:textColor="@color/textColorPrimary"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:paddingHorizontal="16dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>